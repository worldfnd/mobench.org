{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!assets/|og/|llms\\.txt).*)",
      "has": [
        {
          "type": "host",
          "value": "docs.mobench.org"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|og/|llms\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
