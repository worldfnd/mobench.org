{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "docs.mobench.org" }],
      "destination": "/docs",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/((?!assets/|og/|llms\\.txt).*)", "destination": "/index.html" }]
}
