---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Page not found — mobench" description="This Mobench page does not exist." noindex>
  <main id="main-content" class="error-page">
    <a class="brand" href="/"><span class="brand-mark">m</span><span>mobench</span></a>
    <div><p class="eyebrow">404 / route missing</p><h1>This path did not finish the run.</h1><p>The page may have moved to the canonical documentation host.</p><nav><a class="button" href="/">Back to mobench.org</a><a class="text-link" href="https://docs.mobench.org/">Search the documentation →</a></nav></div>
  </main>
  <style>
    .error-page{width:min(100% - 2rem,68rem);min-height:100svh;margin:auto;padding-block:2rem;display:grid;grid-template-rows:auto 1fr}.error-page>div{align-self:center;max-width:47rem;padding-block:4rem}.error-page h1{font-size:clamp(3.5rem,10vw,7.5rem);line-height:.9;letter-spacing:-.07em}.error-page>div>p:not(.eyebrow){max-width:34rem;color:var(--muted);font-size:1.15rem}.error-page nav{display:flex;margin-top:2rem;align-items:center;flex-wrap:wrap;gap:1.5rem}
  </style>
</BaseLayout>
