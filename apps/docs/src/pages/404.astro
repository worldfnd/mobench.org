---
import '../styles/mobench.css'
---

<!doctype html>
<html lang="en" data-theme="light">
  <head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><meta name="robots" content="noindex"/><link rel="icon" href="/favicon.svg"/><title>Page not found — mobench docs</title></head>
  <body><main id="main-content"><a class="brand" href="/"><span>m</span>mobench docs</a><div><p>404 / DOCS ROUTE MISSING</p><h1>This page is outside the current manifest.</h1><p>The guide may have moved. Start at the documentation index or use search from any documentation page.</p><nav><a class="primary" href="/">Documentation index →</a><a href="https://mobench.org/">mobench.org ↗</a></nav></div></main></body>
</html>
<style>
  main{width:min(100% - 2rem,68rem);min-height:100svh;margin:auto;padding-block:2rem;display:grid;grid-template-rows:auto 1fr}.brand{display:flex;align-items:center;gap:.7rem;color:var(--sl-color-white);font-weight:650;text-decoration:none}.brand span{display:grid;width:2rem;height:2rem;place-items:center;border-radius:.5rem;background:var(--sl-color-accent);color:var(--sl-color-black);font-family:var(--sl-font-mono)}main>div{align-self:center;max-width:48rem;padding-block:4rem}main>div>p:first-child{color:var(--sl-color-accent);font-family:var(--sl-font-mono);font-size:.7rem;letter-spacing:.12em}h1{margin:.8rem 0 1.5rem;font-size:clamp(3.4rem,9vw,7rem);line-height:.9;letter-spacing:-.07em}main>div>p:not(:first-child){max-width:35rem;color:var(--sl-color-gray-2);font-size:1.1rem}nav{display:flex;margin-top:2rem;flex-wrap:wrap;gap:1.3rem}nav a{color:var(--sl-color-accent);font-weight:620;text-decoration:none}.primary{padding:.75rem 1rem;border-radius:.5rem;background:var(--sl-color-white);color:var(--sl-color-black)}
</style>
